.installed.cfg
*.egg

# Secrets — never commit
.env
.env.*
!.env.example

# Config with real values — never commit
config.yaml
config/config.yaml
!config.yaml.example

# Kalshi RSA private key — never commit
*.pem
*.pem*
*.key
*.key*
secrets/

# Broader secret/credential filename patterns (catches suffixed variants like .bak, .txt)
secret*.yaml
secret*.yml
secret*.env
secret*.json
*secret*.yaml
*secret*.yml
*secret*.json
*_secret.*
*-secret.*
*credential*.yaml
*credential*.yml
*credential*.json
*.credentials*

# Config with secret values — broader pattern catches config.yaml.bak etc.
config*.yaml*
config*.yml*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Local working notes / session transcripts — not part of the codebase
claudeconversations/

# Logs
*.log
logs/
*.csv
*.jsonl

# Python
.pytest_cache/
*.egg-info/

