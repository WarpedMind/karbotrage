system:
  debug: true
  log_level: INFO
  log_file: karbotrage.log
  paper_resolution_delay_seconds: 300   # seconds before TradeResolvedEvent fires in paper mode

trading:
  mode: paper
  max_positions: 10
  position_size: 1000
  risk_tolerance: 0.02

api:
  polymarket:
    enabled: false
    # api_key is NOT stored here
    # Set environment variable: KALSHI_API_KEY_ID (Kalshi uses RSA key auth)
    base_url: "https://api.polymarket.com"
  kalshi:
    enabled: false
    # api_key is NOT stored here
    # Set environment variables: KALSHI_API_KEY_ID and KALSHI_PRIVATE_KEY_PATH
    # See .env.example for setup instructions
    base_url: "https://api.kalshi.com"

strategy:
  enabled: true
  name: "basic_strategy"
  parameters:
    threshold: 0.1
    max_loss: 0.05
    max_gain: 0.2

monitoring:
  enabled: true
  metrics:
    - "market_data"
    - "trades"
    - "portfolio"

# ── Telegram notifications ─────────────────────────────────────────────────────
# bot_token and chat_id are NOT stored here.
# Set environment variables: TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID
# See .env.example for setup instructions.
telegram:
  enabled: false
  notify_on_trade: true
  notify_on_rejection: false
  permission_timeout_seconds: 300

# ── Regulatory compliance ──────────────────────────────────────────────────────
# Set regulatory_halt to true manually after reading regulatory guidance
# that requires halting operations. Bot refuses to start when true.
# Document your reasoning in compliance_actions.jsonl before clearing.
regulatory_halt: false
regulatory_halt_reason: ""

# How often to poll regulatory sources (hours)
regulatory_check_interval_hours: 6

# ── Regulatory Intelligence Agent ─────────────────────────────────────────────
# Anthropic API key is NOT stored here.
# Set environment variable: ANTHROPIC_API_KEY
# See .env.example for setup instructions.
regulatory_intelligence:
  enabled: true
  regulatory_ai_calls_per_cycle: 10
  regulatory_ai_daily_cap: 50
  regulatory_circuit_breaker_calls: 20
  regulatory_circuit_breaker_window_minutes: 10
  regulatory_cost_per_call_usd: 0.003
  regulatory_clear_phrase: "CLEAR REGULATORY HOLD"
  regulatory_keywords:
    - prediction market
    - event contract
    - CFTC
    - enforcement
    - insider trading
    - manipulation
    - wash trading
    - DEATH BETS
    - self-reporting
    - declination
    - Van Dyke
  weekly_sweep_day: sunday
  weekly_sweep_hour_utc: 6
  poll_interval_hours: 6
